{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "HoneyGrid": {
    "SensorId": "cowrie-shipper-01",
    "SensorType": "ssh",
