# ============================================================================
# HoneyGrid — sensory na zewnętrznym VPS (szablon konfiguracji)
#
#   1. Skopiuj ten plik:   cp .env.example .env
#   2. Uzupełnij wartości z kroków 1–2 docs/vps-deployment.md
#   3. Zabezpiecz uprawnienia:   chmod 600 .env
#
# Plik .env jest w .gitignore — NIGDY nie commituj go z prawdziwym sekretem.
# ============================================================================

# ── Service Principal (logowanie do Azure z poza chmury) ────────────────────
# Z `az ad sp create-for-rbac` (krok 1). password = AZURE_CLIENT_SECRET.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=wstaw-tutaj-haslo-z-create-for-rbac

# ── Event Hubs (cel zdarzeń) ────────────────────────────────────────────────
# FQDN namespace’a Event Hubs, np. hg-dev-ehns-xxxx.servicebus.windows.net
HONEYGRID_EVENTHUB_NAMESPACE=hg-dev-ehns-xxxx.servicebus.windows.net
HONEYGRID_EVENTHUB_NAME=honeypot-events

# ── Blob Storage (nagrania TTY → Session Replay) ────────────────────────────
# Endpoint blob konta Storage, np. https://hgdevstxxxx.blob.core.windows.net
# Wymaga roli "Storage Blob Data Contributor" dla Service Principal (krok 2).
# Pozostaw pusty, jeśli nie chcesz wysyłać nagrań TTY (Live Feed i tak działa).
HONEYGRID_BLOB_ENDPOINT=https://hgdevstxxxx.blob.core.windows.net

# ── Container Registry (skąd Docker pobiera obrazy) ─────────────────────────
# Login server ACR, np. hgdevacrxxxx.azurecr.io
HONEYGRID_ACR=hgdevacrxxxx.azurecr.io

# ── Etykieta lokalizacji tego VPS (widoczna w SensorId) ─────────────────────
# Dowolny krótki znacznik geograficzny, np. frankfurt / helsinki / nyc.
HONEYGRID_SITE=frankfurt
